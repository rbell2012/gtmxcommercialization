    %% ────────── HISTORY / AUDIT ──────────

    member_team_history {
        uuid id PK
        uuid member_id FK
        uuid team_id FK
        timestamptz started_at
        timestamptz ended_at
    }

    team_goals_history {
        uuid id PK
        uuid team_id FK
        text month
        bool goals_parity
        jsonb team_goals
        jsonb enabled_goals
        jsonb accelerator_config
        text accelerator_mode
        jsonb basic_accelerator_config
        jsonb team_goals_by_level
        jsonb goal_scope_config
        timestamptz created_at
    }

    member_goals_history {
        uuid id PK
        uuid member_id FK
        text month
        jsonb goals
        text level
        timestamptz created_at
    }

    funnel_edit_log {
        uuid id PK
        uuid member_id FK
        text week_key
        text edited_by
        timestamptz edited_at
    }

    audit_log {
        uuid id PK
        text table_name
        text record_id
        text action
        jsonb old_data
        jsonb new_data
        timestamptz changed_at
    }

    %% ────────── IMPACT / FUTURE ──────────

    revx_impact_values {
        uuid id PK
        uuid team_id FK
        numeric value_per_win
        timestamptz created_at
        timestamptz updated_at
    }

    activation_adoption_entries {
        uuid id PK
        uuid member_id FK
        uuid team_id FK
        text metric_name
        numeric metric_value
        text week_key
        text notes
        timestamptz created_at
        timestamptz updated_at
    }

    gtmx_impact_entries {
        uuid id PK
        uuid team_id FK
        text metric_name
        numeric metric_value
        text period
        text notes
        timestamptz created_at
        timestamptz updated_at
    }

    %% ═══════════════════════════════════════════
    %% RELATIONSHIPS
    %% ═══════════════════════════════════════════

    %% Core: teams → members → funnels / wins
    teams ||--o{ members : "has"
    members ||--o{ weekly_funnels : "logs weekly"
    members ||--o{ win_entries : "records"

    %% Team-scoped config
    teams ||--o{ team_phase_labels : "labels phases"
    teams ||--o{ team_phase_priorities : "prioritizes phases"
    teams ||--o| revx_impact_values : "has impact value"

    %% History tracking
    members ||--o{ member_team_history : "tracked in"
    teams ||--o{ member_team_history : "had member"
    teams ||--o{ team_goals_history : "snapshot goals"
    members ||--o{ member_goals_history : "snapshot goals"
    members ||--o{ funnel_edit_log : "edits tracked"

    %% Future tables
    members ||--o{ activation_adoption_entries : "activation"
    teams ||--o{ activation_adoption_entries : "adoption"
    teams ||--o{ gtmx_impact_entries : "impact"

    %% Forecasting & sales team assignments
    metrics_sales_teams {
        uuid id PK
        text manager_name
        text manager_title
        text location_reference
        int team_size
        numeric avg_monthly_wins
        text team_members
        timestamptz created_at
        timestamptz updated_at
    }

    metrics_projected_bookings {
        uuid id PK
        text month
        uuid team_id FK
        int projected_bookings
        int new_business_attach
        int growth_wins
        timestamptz created_at
    }

    project_team_assignments {
        uuid id PK
        uuid team_id FK
        uuid sales_team_id FK
        timestamptz created_at
    }

    teams ||--o{ metrics_projected_bookings : "forecasts"
    teams ||--o{ project_team_assignments : "assigned teams"
    metrics_sales_teams ||--o{ project_team_assignments : "assigned to"

    %% External metrics (linked by rep_name, no FK)
    members }o..o{ superhex : "rep_name"
    members }o..o{ metrics_tam : "rep_name"
    members }o..o{ metrics_demos : "rep_name"
    members }o..o{ metrics_ops : "rep_name"
    members }o..o{ metrics_wins : "rep_name"
    members }o..o{ metrics_feedback : "rep_name"
    members }o..o{ metrics_activity : "rep_name"
    members }o..o{ metrics_calls : "rep_name"
    members }o..o{ metrics_connects : "rep_name"
    members }o..o{ metrics_chorus : "rep_name"
