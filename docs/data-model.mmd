        text account_name
        text source
        text feedback
        timestamptz created_at
        timestamptz updated_at
    }

    metrics_activity {
        uuid id PK
        date activity_date
        text salesforce_accountid
        text rep_name
        text activity_type
        text subject
        text status
        text activity_outcome
        text activity_source
        timestamptz created_at
        timestamptz updated_at
    }

    metrics_calls {
        uuid id PK
        date call_date
        text salesforce_accountid
        text rep_name
        text call_type
        text subject
        text status
        text call_outcome
        text call_source
        timestamptz created_at
        timestamptz updated_at
    }

    metrics_connects {
        uuid id PK
        date connect_date
        text salesforce_accountid
        text rep_name
        text connect_type
        text subject
        text status
        text connect_outcome
