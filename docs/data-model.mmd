erDiagram
    %% ═══════════════════════════════════════════
    %% GTMx Commercialization — Data Model
    %% ═══════════════════════════════════════════

    %% ────────── CORE DOMAIN ──────────

    teams {
        uuid id PK
        text name
        text owner
        text lead_rep
        int sort_order
        bool is_active
        date start_date
        date end_date
        int total_tam
        bool tam_submitted
        bool goals_parity
        int team_goal_calls
        int team_goal_ops
        int team_goal_demos
        int team_goal_wins
        int team_goal_feedback
        int team_goal_activity
        bool goal_enabled_calls
        bool goal_enabled_ops
        bool goal_enabled_demos
        bool goal_enabled_wins
        bool goal_enabled_feedback
        bool goal_enabled_activity
        jsonb accelerator_config
        text accelerator_mode
        jsonb basic_accelerator_config
        jsonb team_goals_by_level
        jsonb goal_scope_config
        text mission_purpose
        bool mission_submitted
        timestamptz mission_last_edit
        text executive_sponsor
        text executive_proxy
        text revenue_lever
        text business_goal
        text what_we_are_testing
        timestamptz archived_at
        timestamptz created_at
        timestamptz updated_at
    }

    members {
        uuid id PK
        uuid team_id FK
        text name
        int goal_calls
        int goal_ops
        int goal_demos
        int goal_wins
        int goal_feedback
        int goal_activity
        int ducks_earned
        bool is_active
        text level
        int sort_order
        timestamptz archived_at
        timestamptz created_at
        timestamptz updated_at
    }

    weekly_funnels {
        uuid id PK
        uuid member_id FK
        text week_key
        text role
        int tam
        int calls
        int connects
        int ops
        int demos
        int wins
        int feedback
        int activity
        bool submitted
        timestamptz submitted_at
    }

    win_entries {
        uuid id PK
        uuid member_id FK
        text restaurant
        text story
        date date
        timestamptz created_at
    }

    %% ────────── SETTINGS / CONFIG ──────────

    test_phases {
        uuid id PK
        text month
        text label
        int progress
        int sort_order
        timestamptz created_at
        timestamptz updated_at
    }

    mission {
        uuid id PK
        text content
        bool submitted
        timestamptz updated_at
    }

    tam_config {
        uuid id PK
        int total_tam
        bool submitted
        timestamptz updated_at
    }

    custom_roles {
        uuid id PK
        text name UK
        timestamptz created_at
    }

    team_phase_labels {
        uuid id PK
        uuid team_id FK
        int month_index
        text label
        timestamptz created_at
        timestamptz updated_at
    }

    team_phase_priorities {
        uuid id PK
        uuid team_id FK
        int month_index
        text priority
        timestamptz created_at
        timestamptz updated_at
    }

    findings {
        uuid id PK
        text content
        timestamptz created_at
    }

    %% ────────── EXTERNAL METRICS (by rep_name) ──────────

    superhex {
        uuid id PK
        text salesforce_accountid
        text account_name
        text rep_name
        int total_activities
        date first_activity_date
        date last_activity_date
        int total_calls
        date first_call_date
        date last_call_date
        int total_connects
        date first_connect_date
        text chorus_link
        date chorus_date
        int total_demos
        date first_demo_date
        text op_name
        date op_date
        text op_stage
        bool is_won
        date win_date
        text feedback
        date feedback_date
        timestamptz created_at
        timestamptz updated_at
    }

    metrics_tam {
        uuid id PK
        text source
        text rep_name
        int tam
        timestamptz created_at
        timestamptz updated_at
    }

    metrics_demos {
        uuid id PK
        date demo_date
        text demo_source
        text salesforce_accountid
        text rep_name
        text account_name
        text subject
        timestamptz created_at
        timestamptz updated_at
    }

    metrics_ops {
        uuid id PK
        date op_date
        text opportunity_name
        text opportunity_stage
        text salesforce_accountid
        text rep_name
        text gtmx_team
        text account_prospecting_notes
        text opportunity_type
        date op_created_date
        date win_stage_date
        numeric opportunity_software_mrr
        timestamptz created_at
        timestamptz updated_at
    }

    metrics_wins {
        uuid id PK
