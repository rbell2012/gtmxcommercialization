# Supabase (required for app)
# Copy to .env.local and fill with values from Supabase Dashboard → Project Settings → API
# Vite uses VITE_ prefix for client-side env.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_USE_STATIC_METRICS=false

# Optional static-metadata UI label source.
# Produced by scripts/snowflake_sync.py in CI and served from /public/data/sync_metadata.json.
# No local env var needed.

# Server / Edge Function only (set in Supabase secrets, not here):
# HEX_API_TOKEN=
# HEX_PROJECT_ID=

# Snowflake sync (required for scripts/snowflake_sync.py)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=

# Supabase service credentials for sync upserts + pilot bridge table build
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Sheet IDs (for read_google_sheet_to_table pre-step)
SHEET_ALL_REPS_IN_TESTS_ID=
SHEET_MAD_MAX_ID=
SHEET_STERNO_ID=
SHEET_OFFERS_FEEDBACK_ID=
